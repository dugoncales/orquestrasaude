{
  "meta": {
    "schema_version": "3.1.0",
    "updated_at": "2026-04-22",
    "owner_team": "Produto + Clinical Ops + Engenharia",
    "status": "draft",
    "change_log": [
      "Adicionado versionamento e metadados de governanca.",
      "RBAC normalizado por recurso e acao.",
      "State machines para jornada, etapa, tarefa e alerta.",
      "Automacoes com severidade, janela temporal e cooldown.",
      "Governanca de IA com confidence, evidencias e aprovacao humana.",
      "Dicionario de metricas BI com formula e granularidade."
    ]
  },
  "project": {
    "name": "CareJourney One",
    "version": "3.1 Executable Premium",
    "language": "pt-BR",
    "goal": "Transformar o acompanhamento ambulatorial em uma gestao orientada por jornada, proximos passos, desfechos e produtividade assistencial."
  },
  "hard_rules": [
    "Nao criar app simples de cadastro",
    "A jornada clinica deve ser a tela principal",
    "Toda linha deve ter metas, parametros, tarefas e questionarios"
  ],
  "rbac": [
    {
      "resource": "patients",
      "actions": [
        "read",
        "create",
        "update",
        "assign_care_line"
      ],
      "roles_allowed": [
        "professional",
        "admin"
      ]
    },
    {
      "resource": "journeys",
      "actions": [
        "read",
        "update_step",
        "close_step",
        "reopen_step"
      ],
      "roles_allowed": [
        "professional",
        "admin"
      ]
    },
    {
      "resource": "dashboards_executive",
      "actions": [
        "read"
      ],
      "roles_allowed": [
        "manager",
        "admin"
      ]
    },
    {
      "resource": "self_journey",
      "actions": [
        "read",
        "respond_prom",
        "respond_prem"
      ],
      "roles_allowed": [
        "patient"
      ]
    }
  ],
  "state_machines": {
    "journey": {
      "states": [
        "nao_iniciado",
        "em_andamento",
        "em_reavaliacao",
        "concluido",
        "suspenso"
      ],
      "transitions": [
        {
          "from": "nao_iniciado",
          "to": [
            "em_andamento",
            "suspenso"
          ]
        },
        {
          "from": "em_andamento",
          "to": [
            "em_reavaliacao",
            "suspenso",
            "concluido"
          ]
        },
        {
          "from": "em_reavaliacao",
          "to": [
            "em_andamento",
            "concluido",
            "suspenso"
          ]
        }
      ]
    },
    "task": {
      "states": [
        "pendente",
        "em_andamento",
        "concluida",
        "cancelada",
        "atrasada"
      ],
      "transitions": [
        {
          "from": "pendente",
          "to": [
            "em_andamento",
            "cancelada",
            "atrasada"
          ]
        },
        {
          "from": "em_andamento",
          "to": [
            "concluida",
            "atrasada",
            "cancelada"
          ]
        }
      ]
    },
    "alert": {
      "states": [
        "novo",
        "triagem",
        "em_intervencao",
        "resolvido",
        "silenciado"
      ],
      "transitions": [
        {
          "from": "novo",
          "to": [
            "triagem",
            "silenciado"
          ]
        },
        {
          "from": "triagem",
          "to": [
            "em_intervencao",
            "resolvido"
          ]
        },
        {
          "from": "em_intervencao",
          "to": [
            "resolvido"
          ]
        }
      ]
    }
  },
  "clinical_goals": {
    "policy": [
      "meta_por_linha",
      "meta_por_paciente_override",
      "faixas_por_subgrupo",
      "validade_por_periodo"
    ],
    "goal_record_model": {
      "patient_id": "uuid",
      "care_line_id": "slug",
      "parameter": "string",
      "target_type": "lt|lte|gt|gte|range",
      "target_min": "number|null",
      "target_max": "number|null",
      "effective_from": "date",
      "effective_to": "date|null",
      "updated_by": "user_id"
    }
  },
  "automation_engine": {
    "enabled": true,
    "rule_contract": {
      "name": "string",
      "severity": "low|medium|high|critical",
      "lookback_window_days": "number",
      "cooldown_hours": "number",
      "required_data_quality_score": "0-100",
      "requires_human_validation": "boolean",
      "if": "expression",
      "then": [
        "actions"
      ]
    },
    "rules": [
      {
        "name": "Diabetes fora da meta",
        "severity": "high",
        "lookback_window_days": 180,
        "cooldown_hours": 72,
        "required_data_quality_score": 80,
        "requires_human_validation": true,
        "if": "hba1c > meta_individual",
        "then": [
          "gerar_alerta_clinico",
          "sugerir_retorno_prioritario",
          "abrir_tarefa_educacao_em_saude"
        ]
      },
      {
        "name": "Falta em consulta",
        "severity": "medium",
        "lookback_window_days": 30,
        "cooldown_hours": 24,
        "required_data_quality_score": 60,
        "requires_human_validation": false,
        "if": "status_consulta = faltou",
        "then": [
          "abrir_busca_ativa",
          "sugerir_reagendamento"
        ]
      }
    ]
  },
  "ai_governance": {
    "module_name": "Clinical Insight AI",
    "required_audit_fields": [
      "analysis_id",
      "model_version",
      "input_snapshot_id",
      "confidence_score",
      "evidence_fields",
      "clinical_risk_if_ignored",
      "approved_by",
      "approved_at"
    ],
    "safety_policies": [
      "nao substituir julgamento clinico",
      "exigir validacao humana em severidade high/critical",
      "explicar racional em linguagem clinica"
    ]
  },
  "bi_metric_dictionary": [
    {
      "name": "taxa_de_adesao",
      "definition": "Percentual de pacientes com tarefas obrigatorias concluidas no periodo.",
      "formula": "pacientes_com_tarefas_concluidas / pacientes_ativos",
      "grain": "care_line|unit|professional",
      "refresh_frequency": "daily",
      "owner": "Clinical Ops",
      "target": ">= 0.80"
    },
    {
      "name": "tempo_medio_entre_etapas",
      "definition": "Tempo medio (dias) para transicao entre etapas da jornada.",
      "formula": "avg(data_etapa_n - data_etapa_n_1)",
      "grain": "care_line|unit",
      "refresh_frequency": "daily",
      "owner": "Operations",
      "target": "<= 21"
    }
  ],
  "implementation_phases": [
    {
      "phase": "F1_Fundacional",
      "weeks": "4-6",
      "deliverables": [
        "RBAC em backend",
        "state machines",
        "jornada longitudinal unificada",
        "2 linhas piloto (diabetes/hipertensao)"
      ]
    },
    {
      "phase": "F2_Orquestracao",
      "weeks": "4-8",
      "deliverables": [
        "motor de alertas com severidade",
        "tarefas multiprofissionais",
        "PROM/PREM com timepoints",
        "dashboard profissional por risco"
      ]
    },
    {
      "phase": "F3_Inteligencia_Escala",
      "weeks": "6-10",
      "deliverables": [
        "BI 3 camadas",
        "editor no-code versionado",
        "IA com trilha auditavel",
        "auditoria e compliance"
      ]
    }
  ],
  "journey_slo": {
    "transition_slo_days": {
      "from_assessment_to_plan": 14,
      "from_plan_to_first_followup": 21
    },
    "owner": "Operations",
    "monitoring_frequency": "daily"
  }
}
